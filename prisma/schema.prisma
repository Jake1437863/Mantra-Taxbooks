generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  company      String?
  gstNumber    String?
  cinNumber    String?
  address      String?  @db.Text
  city         String?
  state        String?
  pincode      String?
  passwordHash String
  role         UserRole @default(CLIENT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoices              Invoice[]
  documents             Document[]
  ticketsAsClient       Ticket[]             @relation("ClientTickets")
  ticketsAssigned       Ticket[]             @relation("AssignedTickets")
  ticketMessages        TicketMessage[]
  passwordResets        PasswordReset[]
  impersonationTokens   ImpersonationToken[]
  delegationsAsOwner    Delegation[]         @relation("DelegationOwner")
  delegationsAsDelegate Delegation[]         @relation("DelegationDelegate")

  @@map("users")
}

enum UserRole {
  ADMIN
  CLIENT
  SUPPORT
  PAYMENTS
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNo     String        @unique
  clientId      String
  client        User          @relation(fields: [clientId], references: [id])
  type          InvoiceType   @default(PROFORMA)
  status        InvoiceStatus @default(PENDING)
  items         Json
  subtotal      Decimal       @db.Decimal(10, 2)
  gstRate       Decimal       @db.Decimal(5, 2)  @default(18)
  gstAmount     Decimal       @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  notes         String?       @db.Text
  dueDate       DateTime?
  paidAt        DateTime?
  taxInvoiceId  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("invoices")
}

enum InvoiceType {
  PROFORMA
  TAX
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

model Document {
  id          String         @id @default(cuid())
  clientId    String
  client      User           @relation(fields: [clientId], references: [id])
  uploadedBy  String
  s3Key       String
  filename    String
  mimeType    String
  size        Int
  status      DocumentStatus @default(PENDING)
  reviewNotes String?        @db.Text
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("documents")
}

enum DocumentStatus {
  PENDING
  UNDER_REVIEW
  REVIEWED
  REJECTED
}

model Ticket {
  id         String        @id @default(cuid())
  ticketNo   String        @unique
  clientId   String
  client     User          @relation("ClientTickets", fields: [clientId], references: [id])
  assignedTo String?
  assignee   User?         @relation("AssignedTickets", fields: [assignedTo], references: [id])
  title      String
  status     TicketStatus  @default(OPEN)
  priority   Priority      @default(MEDIUM)
  messages   TicketMessage[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("tickets")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("ticket_messages")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_resets")
}

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String   @db.Text
  createdAt   DateTime @default(now())

  @@map("custom_roles")
}

model ImpersonationToken {
  id        String   @id @default(cuid())
  adminId   String
  clientId  String
  client    User     @relation(fields: [clientId], references: [id])
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("impersonation_tokens")
}

model Delegation {
  id         String           @id @default(cuid())
  ownerId    String
  owner      User             @relation("DelegationOwner", fields: [ownerId], references: [id])
  delegateId String?
  delegate   User?            @relation("DelegationDelegate", fields: [delegateId], references: [id])
  email      String
  token      String?          @unique
  status     DelegationStatus @default(PENDING)
  createdAt  DateTime         @default(now())

  @@map("delegations")
}

enum DelegationStatus {
  PENDING
  ACTIVE
  REVOKED
}
